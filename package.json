{
  "name": "plotholders",
  "version": "1.0.0",
  "description": "Plot Holders Club loyalty program backend",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run build:admin && npm run build:staff && npm run build:portal && tsc",
    "build:admin": "vite build --config vite.admin.config.ts",
    "build:staff": "vite build --config vite.staff.config.ts",
    "build:portal": "vite build --config vite.portal.config.ts",
    "dev:admin": "vite --config vite.admin.config.ts",
    "dev:staff": "vite --config vite.staff.config.ts",
    "dev:portal": "vite --config vite.portal.config.ts",
    "start": "node dist/index.js",
    "seed": "tsx scripts/seed.ts",
    "migrate": "tsx scripts/migrate.ts",
    "typecheck": "tsc --noEmit",
    "db:init": "psql $DATABASE_URL -f src/db/schema.sql || echo 'Run: psql $DATABASE_URL -f src/db/schema.sql'",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "loyalty",
    "plot-holders",
    "shopify"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@shopify/app-bridge-react": "^4.1.0",
    "@shopify/polaris": "^12.27.0",
    "@shopify/shopify-api": "^13.0.0",
    "cookie-parser": "^1.4.7",
    "csv-parser": "^3.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "pg": "^8.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "redis": "^6.0.0",
    "resend": "^6.12.4",
    "twilio": "^6.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^25.9.1",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "nodemon": "^3.1.14",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^5.4.2"
  }
}
