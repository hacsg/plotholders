# Database
DATABASE_URL=postgresql://user:password@localhost:5432/plotholders

# Redis (Railway Redis or Upstash — required for magic links / SMS codes / winback cooldown)
REDIS_URL=redis://localhost:6379

# JWT (generate a long random string for production)
JWT_SECRET=your-super-secret-key-here-change-in-prod

# Twilio (SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15551234567

# Resend (Transactional email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Application
APP_URL=https://plotholders.hundredacre.sg

# Shopify OAuth (Embedded App)
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret
SHOPIFY_HOST=plotholders.hundredacre.sg
# Set to true locally to skip full OAuth during development
SKIP_SHOPIFY_AUTH=true

# Shopify (legacy / optional)
SHOPIFY_ACCESS_TOKEN=your-admin-api-access-token
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Server
PORT=3000
NODE_ENV=development

# Optional: Webhook secrets
SHOPIFY_WEBHOOK_SECRET=your-webhook-secret
